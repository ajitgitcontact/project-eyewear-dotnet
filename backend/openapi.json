  "components": {
    "schemas": {
      "CreateCustomizationImageDto": {
        "required": [
          "productId",
          "customizationOptionId",
          "customizationValueId",
          "imageUrl"
        ],
        "type": "object",
        "properties": {
          "productId": {
            "type": "integer",
            "format": "int32"
          },
          "customizationOptionId": {
            "type": "integer",
            "format": "int32"
          },
          "customizationValueId": {
            "type": "integer",
            "format": "int32"
          },
          "imageUrl": {
            "maxLength": 500,
            "type": "string"
          }
        }
      },
      "CreateCustomizationOptionDto": {
        "required": [
          "productId",
          "name"
        ],
        "type": "object",
        "properties": {
          "productId": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "maxLength": 100,
            "type": "string"
          },
          "isRequired": {
            "type": "boolean"
          },
          "displayOrder": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "CreateCustomizationValueDto": {
        "required": [
          "customizationOptionId",
          "value"
        ],
        "type": "object",
        "properties": {
          "customizationOptionId": {
            "type": "integer",
            "format": "int32"
          },
          "value": {
            "maxLength": 100,
            "type": "string"
          },
          "additionalPrice": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        }
      },
      "CreateFullCustomizationImageDto": {
        "required": [
          "imageUrl"
        ],
        "type": "object",
        "properties": {
          "imageUrl": {
            "maxLength": 500,
            "type": "string"
          }
        }
      },
      "CreateFullCustomizationOptionDto": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "type": "string"
          },
          "isRequired": {
            "type": "boolean"
          },
          "displayOrder": {
            "type": "integer",
            "format": "int32"
          },
          "values": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateFullCustomizationValueDto"
            }
          }
        }
      },
      "CreateFullCustomizationValueDto": {
        "required": [
          "value"
        ],
        "type": "object",
        "properties": {
          "value": {
            "maxLength": 100,
            "type": "string"
          },
          "additionalPrice": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "customizationImages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateFullCustomizationImageDto"
            }
          }
        }
      },
      "CreateFullProductDto": {
        "required": [
          "sku",
          "name",
          "category",
          "basePrice"
        ],
        "type": "object",
        "properties": {
          "sku": {
            "maxLength": 50,
            "type": "string"
          },
          "name": {
            "maxLength": 200,
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "brand": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "category": {
            "maxLength": 100,
            "type": "string"
          },
          "basePrice": {
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "hasPrescription": {
            "type": "boolean"
          },
          "customizationOptions": {
