###

# Validation: invalid customization option should fail with 400.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "customer": {
    "name": "Aarav Sharma",
    "email": "aarav@example.com"
  },
  "address": {
    "type": "SHIPPING",
    "line1": "221 MG Road",
    "city": "Bengaluru",
    "state": "Karnataka",
    "pincode": "560001",
    "country": "India"
  },
  "items": [
    {
      "productId": {{productId}},
      "quantity": 1,
      "customizations": [
        { "customizationOptionId": {{wrongOptionId}} }
      ]
    }
  ],
  "payment": { "method": "COD" }
}

###

