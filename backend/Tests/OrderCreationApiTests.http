@backend_HostAddress = http://localhost:5047
@customerToken = <CUSTOMER_TOKEN>
@adminToken = <ADMIN_TOKEN>
@wrongRoleToken = <TOKEN_WITH_UNAUTHORIZED_ROLE>
@invalidToken = invalid.jwt.value
@productId = 1
@requiredOptionId = 1
@validValueId = 1
@wrongOptionId = 999999
@wrongValueId = 999999

# Test notes:
# - Replace token and product/customization variables before running.
# - Use Swagger or GET /api/products to choose product/customization IDs that exist.
# - Verify rollback cases by checking the database has no rows for the returned/attempted order when a request fails.
# - Discount scenarios currently document placeholder behavior: coupon codes are accepted but discountAmount remains 0.

###

# Authentication: unauthenticated request should fail with 401.
POST {{backend_HostAddress}}/api/orders/create
Content-Type: application/json

{}

###

# Authentication: invalid JWT should fail with 401.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{invalidToken}}
Content-Type: application/json

{}

###

# Authentication: wrong role should fail with 403.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{wrongRoleToken}}
Content-Type: application/json

{}

###

# Validation: empty payload should fail with 400.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{}

###

# Validation: missing customer details should fail with 400.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "address": {
    "type": "SHIPPING",
    "line1": "221 MG Road",
    "city": "Bengaluru",
    "state": "Karnataka",
    "pincode": "560001",
    "country": "India"
  },
  "items": [
    { "productId": {{productId}}, "quantity": 1 }
  ],
  "payment": { "method": "COD" }
}

###

# Validation: missing address should fail with 400.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "customer": {
    "name": "Aarav Sharma",
    "email": "aarav@example.com"
  },
  "items": [
    { "productId": {{productId}}, "quantity": 1 }
  ],
  "payment": { "method": "COD" }
}

###

