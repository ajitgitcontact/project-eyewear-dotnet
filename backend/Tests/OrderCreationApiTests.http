  },
  "items": [
    {
      "productId": {{productId}},
      "quantity": 1,
      "customizations": [
        {
          "customizationOptionId": {{requiredOptionId}},
          "customizationValueId": {{wrongValueId}}
        }
      ]
    }
  ],
  "payment": { "method": "COD" }
}

###

# Validation: invalid prescription data should fail with 400.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "customer": {
    "name": "Aarav Sharma",
    "email": "aarav@example.com"
  },
  "address": {
    "type": "SHIPPING",
    "line1": "221 MG Road",
    "city": "Bengaluru",
    "state": "Karnataka",
    "pincode": "560001",
    "country": "India"
  },
  "items": [
    { "productId": {{productId}}, "quantity": 1 }
  ],
  "prescription": {
    "rightAxis": 181,
    "pd": -1
  },
  "payment": { "method": "COD" }
}

###

# Security: frontend UserId, CustomerOrderId, totals, and statuses should be ignored.
# Expected success if product/customization data is valid; response userId must match JWT,
# customerOrderId must be backend-generated, paymentStatus must be PENDING, status must be INITIATED.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "userId": 999999,
  "customerOrderId": "ATTACKER_ORDER_ID",
  "totalAmount": 1,
  "discountAmount": 999999,
  "paymentStatus": "PAID",
  "orderStatus": "DELIVERED",
  "customer": {
    "name": "Aarav Sharma",
    "email": "aarav@example.com",
    "phone": "9876543210"
  },
  "address": {
    "type": "SHIPPING",
    "line1": "221 MG Road",
    "city": "Bengaluru",
    "state": "Karnataka",
    "pincode": "560001",
    "country": "India"
  },
  "items": [
    {
      "productId": {{productId}},
      "quantity": 1,
      "totalPrice": 1,
      "customizations": [
        {
          "customizationOptionId": {{requiredOptionId}},
          "customizationValueId": {{validValueId}}
        }
      ]
    }
  ],
  "payment": {
    "method": "COD",
    "status": "SUCCESS"
  },
  "couponCode": "ANY_CODE"
}

###

# Success: valid CUSTOMER request should return 201 and CustomerOrderId format YYMMDDXXXXX.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "customer": {
    "name": "Aarav Sharma",
    "email": "aarav@example.com",
    "phone": "9876543210"
  },
  "address": {
    "type": "SHIPPING",
    "line1": "221 MG Road",
    "city": "Bengaluru",
    "state": "Karnataka",
    "pincode": "560001",
    "country": "India"
  },
  "items": [
    {
      "productId": {{productId}},
      "quantity": 1,
      "customizations": [
        {
          "customizationOptionId": {{requiredOptionId}},
          "customizationValueId": {{validValueId}}
        }
      ]
    }
  ],
  "payment": { "method": "COD" },
  "couponCode": "WELCOME500"
}
