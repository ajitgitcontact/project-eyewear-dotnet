@backend_HostAddress = http://localhost:5047
@customerEmail = customer1@eyewear.dev
@customerPassword = Customer@12345
@adminEmail = admin1@eyewear.dev
@adminPassword = Admin@12345

# ------------------------------
# AUTH API
# ------------------------------

# Customer Sign Up (always creates CUSTOMER role)
POST {{backend_HostAddress}}/api/auth/signup
Content-Type: application/json

{
	"firstName": "New",
	"lastName": "Customer",
	"email": "new.customer+{{$timestamp}}@eyewear.dev",
	"password": "Customer@12345",
	"contactNumber": "9191919191"
}

###

# Login as Customer
POST {{backend_HostAddress}}/api/users/login
Content-Type: application/json

{
	"email": "{{customerEmail}}",
	"password": "{{customerPassword}}"
}

###

# Login as Admin
POST {{backend_HostAddress}}/api/users/login
Content-Type: application/json

{
	"email": "{{adminEmail}}",
	"password": "{{adminPassword}}"
}

###

# Database Connection Test
GET {{backend_HostAddress}}/api/dbtest
Accept: application/json

###

# Protected Example (requires Bearer token)
# Replace <TOKEN> with token from login response.
GET {{backend_HostAddress}}/api/users
Authorization: Bearer <TOKEN>
Accept: application/json

###

# Products API - Sorting Examples

# Default sort (by Priority)
GET {{backend_HostAddress}}/api/products
Accept: application/json

###

# Price: Low to High
GET {{backend_HostAddress}}/api/products?sort=price_asc
Accept: application/json

###

# Price: High to Low
GET {{backend_HostAddress}}/api/products?sort=price_desc
Accept: application/json

###

# Popularity (by Sold Quantity - descending)
GET {{backend_HostAddress}}/api/products?sort=popularity
Accept: application/json

###

# What's New (by Created Date - descending)
GET {{backend_HostAddress}}/api/products?sort=newest
Accept: application/json

###

# Get Single Product by ID
GET {{backend_HostAddress}}/api/products/1
Accept: application/json

###

# Get Product by SKU
GET {{backend_HostAddress}}/api/products/sku/PRD-000001
Accept: application/json

###

# ------------------------------
# ORDER CREATION API
# ------------------------------

@customerToken = <CUSTOMER_TOKEN>

# Create complete checkout order.
# Replace product/customization IDs with values from GET /api/products.
POST {{backend_HostAddress}}/api/orders/create
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "customer": {
    "name": "Aarav Sharma",
    "email": "aarav@example.com",
    "phone": "9876543210"
  },
  "address": {
    "type": "SHIPPING",
    "line1": "221 MG Road",
    "line2": "Near Metro Station",
    "city": "Bengaluru",
    "state": "Karnataka",
    "pincode": "560001",
    "country": "India"
  },
  "items": [
    {
      "productId": 1,
      "quantity": 1,
      "customizations": [
        {
          "customizationOptionId": 1,
          "customizationValueId": 1
        }
      ]
    }
  ],
  "payment": {
    "method": "COD",
    "transactionId": null
  },
  "couponCode": "WELCOME500",
  "notes": "Leave package with security."
}

###

# Order creation should fail without authentication.
POST {{backend_HostAddress}}/api/orders/create
Content-Type: application/json

{}

###

# ------------------------------
# ORDER FETCH APIs
# ------------------------------

@customerOrderId = 26050100001
@adminToken = <ADMIN_TOKEN>

# Customer/Admin/Super Admin: fetch complete order by CustomerOrderId.
GET {{backend_HostAddress}}/api/orders/{{customerOrderId}}
Authorization: Bearer {{customerToken}}
Accept: application/json

###

# Admin/Super Admin: search all orders.
GET {{backend_HostAddress}}/api/orders?pageNumber=1&pageSize=20&orderStatus=CREATED&paymentStatus=PENDING
Authorization: Bearer {{adminToken}}
Accept: application/json

###

# Customer: My Orders.
GET {{backend_HostAddress}}/api/customer/orders?pageNumber=1&pageSize=20
Authorization: Bearer {{customerToken}}
Accept: application/json

###

# ------------------------------
# ADMIN DISCOUNTS / COUPONS
# ------------------------------

# Admin/Super Admin: create an all-product percentage discount.
POST {{backend_HostAddress}}/api/admin/discounts
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "discountName": "Launch Sale 10%",
  "discountType": "PERCENTAGE",
  "discountValue": 10,
  "appliesTo": "ALL",
  "startDate": null,
  "endDate": null,
  "isActive": true,
  "productIds": []
}

###

# Admin/Super Admin: create a product-specific flat discount.
POST {{backend_HostAddress}}/api/admin/discounts
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "discountName": "Product 32 Flat 500",
  "discountType": "FLAT",
  "discountValue": 500,
  "appliesTo": "PRODUCT",
  "startDate": null,
  "endDate": null,
  "isActive": true,
  "productIds": [32]
}

###

# Admin/Super Admin: create a customer coupon.
POST {{backend_HostAddress}}/api/admin/coupons
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "couponCode": "WELCOME500",
  "couponName": "Welcome coupon",
  "couponType": "FLAT",
  "couponValue": 500,
  "minimumOrderAmount": 1000,
  "maximumCouponAmount": null,
  "usageLimit": 100,
  "perUserUsageLimit": 1,
  "startDate": null,
  "endDate": null,
  "isActive": true
}

###

# Admin/Super Admin: view order journey logs.
GET {{backend_HostAddress}}/api/orders/{{customerOrderId}}/logs
Authorization: Bearer {{adminToken}}
Accept: application/json

###

# ------------------------------
# CART APIs
# ------------------------------

# Customer: get active cart. Empty cart returns an empty response, not an error.
GET {{backend_HostAddress}}/api/cart
Authorization: Bearer {{customerToken}}
Accept: application/json

###

# Customer: add item to cart.
# Product/customization IDs must come from GET /api/products.
POST {{backend_HostAddress}}/api/cart/items
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "productId": 1,
  "quantity": 1,
  "customizations": [
    {
      "customizationOptionId": 1,
      "customizationValueId": 1
    }
  ],
  "prescription": null
}

###

@cartItemId = cart_items_REPLACE_ME

# Customer: update cart item quantity.
PUT {{backend_HostAddress}}/api/cart/items/{{cartItemId}}
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "quantity": 2
}

###

# Customer: apply coupon preview. Coupon is revalidated during checkout.
POST {{backend_HostAddress}}/api/cart/apply-coupon
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "couponCode": "WELCOME500"
}

###

# Customer: remove coupon preview.
DELETE {{backend_HostAddress}}/api/cart/remove-coupon
Authorization: Bearer {{customerToken}}
Accept: application/json

###

# Customer: checkout active cart through existing order creation flow.
POST {{backend_HostAddress}}/api/cart/checkout
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "customer": {
    "name": "Aarav Sharma",
    "email": "aarav@example.com",
    "phone": "9876543210"
  },
  "address": {
    "type": "SHIPPING",
    "line1": "221 MG Road",
    "line2": "Near Metro Station",
    "city": "Bengaluru",
    "state": "Karnataka",
    "pincode": "560001",
    "country": "India"
  },
  "payment": {
    "method": "COD",
    "transactionId": null
  },
  "notes": "Checkout from cart."
}

###

# Customer: remove cart item.
DELETE {{backend_HostAddress}}/api/cart/items/{{cartItemId}}
Authorization: Bearer {{customerToken}}
Accept: application/json

###

# Customer: clear active cart.
DELETE {{backend_HostAddress}}/api/cart/clear
Authorization: Bearer {{customerToken}}
Accept: application/json

###

# ------------------------------
# WISHLIST APIs
# ------------------------------

# Customer: get wishlist.
GET {{backend_HostAddress}}/api/wishlist
Authorization: Bearer {{customerToken}}
Accept: application/json

###

# Customer: add product to wishlist.
POST {{backend_HostAddress}}/api/wishlist/items
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "productId": 1
}

###

@wishlistItemId = wishlist_items_REPLACE_ME

# Customer: move wishlist item to cart if no product detail configuration is required.
POST {{backend_HostAddress}}/api/wishlist/items/{{wishlistItemId}}/move-to-cart
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "quantity": 1
}

###

# Customer: remove wishlist item.
DELETE {{backend_HostAddress}}/api/wishlist/items/{{wishlistItemId}}
Authorization: Bearer {{customerToken}}
Accept: application/json

###
